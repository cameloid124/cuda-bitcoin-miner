# Copy to .env and fill in your pool credentials:
#   cp .env.example .env

STRATUM_URL=stratum+tcp://pool.example.com:3333
STRATUM_USER=your_wallet_address.worker_name
STRATUM_PASSWORD=x

# --- Docker (optional overrides) ---
# Default below targets Jetson Orin / JetPack 7.2 (ARM64).
# MINER_DOCKERFILE=Dockerfile.jetson
# MINER_IMAGE_TAG=jetson
# DOCKER_PLATFORM=linux/arm64
#
# x86_64 hosts: use the compose override instead of editing these:
#   docker compose -f docker-compose.yml -f docker-compose.x86.yml up --build
